{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "sdk-node#build": {
      "outputs": ["dist/**"]
    },
    "web#build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "web#dev": {
      "cache": false,
      "persistent": true
    },
    "api#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "go.mod", "go.sum", "**/*.go"],
      "outputs": ["bin/**"]
    },
    "api#dev": {
      "cache": false,
      "persistent": true,
      "inputs": ["$TURBO_DEFAULT$", "go.mod", "go.sum", "**/*.go"]
    },
    "zkp-guest#build-zkp": {
      "inputs": ["$TURBO_DEFAULT$", "Cargo.toml", "Cargo.lock", "**/*.rs"],
      "outputs": ["target/**"]
    }
  }
}
