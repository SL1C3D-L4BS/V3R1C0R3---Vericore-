# D3V — Efficiency & Integrity Stack
# Copy to .env and fill in values

# --- LibSQL / Turso (Embedded Replica) ---
LIBSQL_URL=https://your-db-name.your-org.turso.io
LIBSQL_AUTH_TOKEN=your-turso-auth-token

# --- Optional: Local replica path (default: local.db) ---
# LIBSQL_REPLICA_PATH=local.db

# --- MCP Flight Recorder (when running as sidecar) ---
# MCP_SERVER_URL=http://localhost:3001

# --- App ---
API_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8080
